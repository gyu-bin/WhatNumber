{
  "name": "whatnumber",
  "private": true,
  "version": "1.0.0",
  "description": "몇번이야 — 진짜 쓸 일 생기는 공공 전화번호 모음",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "generate-assets": "node scripts/generate-assets.mjs",
    "generate-ads-txt": "node scripts/generate-ads-txt.mjs",
    "generate-sitemap": "node scripts/generate-sitemap.mjs",
    "prebuild": "npm run generate-assets && npm run generate-ads-txt && npm run generate-sitemap",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "mobile": "npm run start --workspace=mobile",
    "mobile:ios": "npm run ios --workspace=mobile",
    "mobile:android": "npm run android --workspace=mobile"
  },
  "dependencies": {
    "@whatnumber/shared": "*",
    "@vercel/analytics": "^2.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
}
